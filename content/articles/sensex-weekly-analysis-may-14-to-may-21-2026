  <style>
    :root {
      --bg: #0e1117;
      --surface: #161b27;
      --surface2: #1e2535;
      --border: #2a3347;
      --text: #e2e8f0;
      --muted: #8896b0;
      --red: #ef4444;
      --green: #22c55e;
      --gold: #f59e0b;
      --blue: #3b82f6;
      --white: #ffffff;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: #0e1117 !important; }
    body { font-family: 'DM Sans', sans-serif; background: #0e1117 !important; color: var(--text); line-height: 1.7; }
    .page-wrapper { background: #0e1117 !important; min-height: 100vh; width: 100%; }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, #0e1117 0%, #1a1f35 60%, #0e1117 100%);
      border-bottom: 1px solid var(--border);
      padding: 56px 24px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -60px; left: 50%; transform: translateX(-50%);
      width: 600px; height: 300px;
      background: radial-gradient(ellipse, rgba(245,158,11,0.10) 0%, transparent 70%);
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(245,158,11,0.15);
      border: 1px solid rgba(245,158,11,0.35);
      color: #fde68a; font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 5px 14px; border-radius: 20px;
      margin-bottom: 20px; position: relative;
    }
    .hero-badge::before {
      content: ''; width: 6px; height: 6px;
      background: var(--gold); border-radius: 50%;
      animation: pulse 1.8s ease infinite;
    }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.3); } }
    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.8rem, 4.5vw, 3rem);
      color: var(--white); line-height: 1.2;
      max-width: 700px; margin: 0 auto 12px; position: relative;
    }
    .hero h1 em { font-style: normal; color: var(--gold); }
    .hero-meta { color: var(--muted); font-size: 0.85rem; position: relative; margin-top: 16px; }

    /* ── TICKER ── */
    .live-bar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      display: flex; align-items: center; font-size: 0.82rem; overflow: hidden;
    }
    .live-label {
      background: var(--gold); color: #000; font-weight: 700;
      font-size: 0.7rem; letter-spacing: 0.1em; padding: 8px 14px;
      white-space: nowrap; flex-shrink: 0;
    }
    .live-scroll { overflow: hidden; flex: 1; padding: 8px 16px; }
    .live-scroll-inner { display: inline-block; white-space: nowrap; animation: scroll 30s linear infinite; }
    .live-scroll-inner span { margin-right: 48px; color: var(--muted); }
    .live-scroll-inner span strong { color: var(--text); }
    .live-scroll-inner span .up { color: var(--green); }
    .live-scroll-inner span .dn { color: var(--red); }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* ── LAYOUT ── */
    article { max-width: 900px; margin: 0 auto; padding: 48px 24px 80px; }
    h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.6rem; color: var(--white);
      margin: 52px 0 16px; display: flex; align-items: center; gap: 10px;
    }
    h2 .icon { font-size: 1.2rem; }
    p { font-size: 0.97rem; color: #c8d4e8; margin-bottom: 14px; line-height: 1.8; }

    /* ── TOC ── */
    .toc-box {
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid var(--gold); border-radius: 0 12px 12px 0;
      padding: 24px 28px; margin: 32px 0 40px;
    }
    .toc-box h3 { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gold); margin: 0 0 16px; font-family: 'DM Sans', sans-serif; }
    .toc-list { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 32px; }
    .toc-list li a { color: #9aadc4; text-decoration: none; font-size: 0.88rem; display: flex; align-items: center; gap: 8px; transition: color 0.2s; }
    .toc-list li a:hover { color: var(--gold); }
    .toc-list li a::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--gold); opacity: 0.5; flex-shrink: 0; }
    .toc-list li a:hover::before { opacity: 1; }

    /* ── SNAPSHOT ── */
    .snapshot { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 28px 0; }
    .snap-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 18px 16px; text-align: center; }
    .snap-card .s-val { font-family: 'DM Serif Display', serif; font-size: 1.6rem; font-weight: 700; display: block; margin-bottom: 4px; }
    .snap-card .s-lbl { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
    .snap-card .s-sub { font-size: 0.75rem; margin-top: 3px; color: var(--muted); }
    .gold { color: var(--gold); } .red { color: var(--red); } .green { color: var(--green); } .blue { color: var(--blue); }

    /* ── ZONE CONTAINER ── */
    .zone-container {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; padding: 32px 28px; margin: 28px 0;
      display: grid; grid-template-columns: 200px 1fr; gap: 32px; align-items: center;
    }
    .zone-thermometer { position: relative; height: 340px; display: flex; flex-direction: column; justify-content: space-between; align-items: center; }
    .therm-track {
      position: absolute; left: 50%; transform: translateX(-50%);
      width: 20px; top: 0; bottom: 0; border-radius: 10px;
      background: linear-gradient(to bottom, rgba(34,197,94,0.3) 0%, rgba(34,197,94,0.15) 20%, rgba(148,163,184,0.1) 35%, rgba(239,68,68,0.15) 70%, rgba(239,68,68,0.3) 100%);
    }
    .therm-level { position: relative; display: flex; align-items: center; width: 100%; z-index: 1; }
    .therm-line { position: absolute; left: 50%; transform: translateX(-50%); width: 36px; height: 2px; }
    .therm-label { position: absolute; left: calc(50% + 24px); white-space: nowrap; font-size: 0.75rem; }
    .therm-value { font-weight: 700; font-size: 0.82rem; display: block; }
    .therm-tag { font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
    .current-marker {
      position: absolute; left: 50%; transform: translateX(-50%);
      background: var(--gold); color: #000;
      font-size: 0.68rem; font-weight: 700;
      padding: 2px 8px; border-radius: 3px; white-space: nowrap; z-index: 2;
    }
    .current-marker::before { content: '▶'; position: absolute; left: -12px; color: var(--gold); }
    .zone-details { display: flex; flex-direction: column; gap: 12px; }
    .zone-row { display: flex; align-items: center; gap: 14px; padding: 14px 16px; background: var(--surface2); border-radius: 8px; border-left: 3px solid transparent; }
    .zone-row.max-up  { border-left-color: #16a34a; }
    .zone-row.up-ent  { border-left-color: #4ade80; }
    .zone-row.current { border-left-color: var(--gold); }
    .zone-row.dn-ent  { border-left-color: #f87171; }
    .zone-row.max-dn  { border-left-color: #dc2626; }
    .zone-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .zone-info .z-price { font-weight: 700; font-size: 1rem; color: var(--white); }
    .zone-info .z-name  { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .zone-gap { margin-left: auto; font-size: 0.75rem; color: var(--muted); }

    /* ── LEVELS TABLE ── */
    .levels-table { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 0.88rem; }
    .levels-table th { background: var(--surface2); color: var(--muted); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.09em; padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); }
    .levels-table td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text); }
    .levels-table tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em; }
    .badge.resistance { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .badge.support    { background: rgba(34,197,94,0.15);  color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .badge.current    { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); }

    /* ── CALLOUT ── */
    .callout {
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid var(--gold); border-radius: 0 8px 8px 0;
      padding: 16px 18px; margin: 20px 0; font-size: 0.92rem; color: #c8d4e8;
    }
    .callout.red-bar   { border-left-color: var(--red); }
    .callout.blue-bar  { border-left-color: var(--blue); }
    .callout.green-bar { border-left-color: var(--green); }
    .callout strong { display: block; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 6px; }

    /* ── GAUGE GRID ── */
    .gauge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 28px 0; }
    .gauge-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
    .gauge-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 16px; }
    .pcr-gauge-wrap { text-align: center; }
    .pcr-svg { width: 100%; max-width: 220px; }
    .pcr-reading { font-family: 'DM Serif Display', serif; font-size: 2rem; color: var(--gold); display: block; margin-top: 8px; }
    .pcr-status { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }
    .pcr-legend { display: flex; justify-content: space-between; margin-top: 10px; font-size: 0.68rem; color: var(--muted); }
    .vix-value-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px; }
    .vix-big { font-family: 'DM Serif Display', serif; font-size: 2.4rem; color: var(--gold); }
    .vix-change { font-size: 0.85rem; color: var(--green); }
    .vix-track {
      width: 100%; height: 12px;
      background: linear-gradient(90deg, #22c55e 0%, #84cc16 20%, #f59e0b 45%, #f97316 65%, #ef4444 85%, #7f1d1d 100%);
      border-radius: 6px; position: relative; margin-bottom: 6px;
    }
    .vix-needle {
      position: absolute; top: -5px; width: 4px; height: 22px;
      background: var(--white); border-radius: 2px; transform: translateX(-50%);
      left: 29.5%; /* 18.84 on scale 10-40: (18.84-10)/(40-10)=29.5% */
      box-shadow: 0 0 6px rgba(255,255,255,0.5);
    }
    .vix-scale { display: flex; justify-content: space-between; font-size: 0.65rem; color: var(--muted); }
    .vix-zones { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 14px; }
    .vix-zone { text-align: center; padding: 6px 4px; border-radius: 4px; font-size: 0.65rem; font-weight: 600; }
    .vix-zone.calm  { background: rgba(34,197,94,0.15);  color: #4ade80; }
    .vix-zone.mod   { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); }
    .vix-zone.high  { background: rgba(249,115,22,0.15); color: #fb923c; border: 1px solid rgba(249,115,22,0.3); }
    .vix-zone.panic { background: rgba(239,68,68,0.15);  color: #f87171; }

    /* ── OI ── */
    .oi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0; }
    .oi-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .oi-card h4 { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 14px; }
    .oi-bar-item { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .oi-strike { font-size: 0.8rem; font-weight: 600; color: var(--text); min-width: 60px; }
    .oi-track { flex: 1; height: 8px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; }
    .oi-fill-call { height: 100%; border-radius: 4px; background: linear-gradient(90deg,#dc2626,#ef4444); animation: grow 1s ease forwards; transform-origin: left; }
    .oi-fill-put  { height: 100%; border-radius: 4px; background: linear-gradient(90deg,#16a34a,#22c55e); animation: grow 1s ease forwards; transform-origin: left; }
    @keyframes grow { from { transform: scaleX(0); } to { transform: scaleX(1); } }
    .oi-label { font-size: 0.7rem; color: var(--muted); min-width: 40px; text-align: right; }

    /* ── RANGE VISUAL ── */
    .range-visual { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 28px; margin: 24px 0; }
    .range-visual h4 { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 20px; }
    .range-track-wrap { position: relative; height: 48px; margin: 0 0 10px; }
    .range-bg {
      position: absolute; inset: 0; border-radius: 8px;
      background: linear-gradient(90deg, rgba(239,68,68,0.25) 0%, rgba(239,68,68,0.1) 15%, rgba(245,158,11,0.08) 30%, rgba(148,163,184,0.06) 45%, rgba(34,197,94,0.08) 65%, rgba(34,197,94,0.1) 80%, rgba(34,197,94,0.25) 100%);
    }
    .range-marker { position: absolute; top: 0; bottom: 0; width: 2px; transform: translateX(-50%); }
    .range-marker-label { position: absolute; top: -22px; transform: translateX(-50%); font-size: 0.65rem; font-weight: 700; white-space: nowrap; }
    .range-marker-val   { position: absolute; bottom: -20px; transform: translateX(-50%); font-size: 0.7rem; white-space: nowrap; }
    .range-scale { display: flex; justify-content: space-between; margin-top: 28px; font-size: 0.7rem; color: var(--muted); }

    /* ── CROSS-PAGE LINK CARD ── */
    .link-card {
      display: flex; align-items: center; gap: 16px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 16px 20px; margin: 16px 0;
      text-decoration: none; transition: border-color 0.2s, background 0.2s;
    }
    .link-card:hover { border-color: rgba(245,158,11,0.4); background: rgba(245,158,11,0.04); }
    .link-card-icon { font-size: 1.6rem; flex-shrink: 0; }
    .link-card-body .lc-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: 600; margin-bottom: 3px; }
    .link-card-body .lc-title { font-size: 0.9rem; font-weight: 600; color: var(--white); line-height: 1.3; }
    .link-card-body .lc-desc  { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
    .link-card-arrow { margin-left: auto; color: var(--muted); font-size: 1rem; flex-shrink: 0; }

    /* ── FAQ ── */
    .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { font-weight: 600; color: var(--white); display: flex; gap: 12px; }
    .faq-q::before { content: "Q"; background: rgba(245,158,11,0.2); color: var(--gold); font-size: 0.68rem; font-weight: 700; padding: 2px 7px; border-radius: 3px; flex-shrink: 0; margin-top: 2px; border: 1px solid rgba(245,158,11,0.3); }
    .faq-a { font-size: 0.92rem; color: #9aadc4; margin-top: 10px; padding-left: 34px; line-height: 1.75; }

    /* ── RELATED ARTICLES ── */
    .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 20px 0; }
    .related-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 18px; text-decoration: none; display: block; transition: border-color 0.2s, background 0.2s; }
    .related-card:hover { border-color: rgba(245,158,11,0.35); background: rgba(245,158,11,0.04); }
    .related-card .rc-tag { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: 600; margin-bottom: 8px; display: block; }
    .related-card .rc-title { font-size: 0.88rem; font-weight: 600; color: var(--white); line-height: 1.4; margin-bottom: 6px; }
    .related-card .rc-desc  { font-size: 0.75rem; color: var(--muted); line-height: 1.5; }

    /* ── DISCLAIMER / FOOTER ── */
    .disclaimer { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 18px 22px; font-size: 0.82rem; color: var(--muted); margin-top: 48px; line-height: 1.7; }
    footer { margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 0.82rem; color: var(--muted); }
    .back-to-top { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-size: 0.78rem; text-decoration: none; margin-top: 12px; transition: color 0.2s; }
    .back-to-top:hover { color: var(--gold); }

    @media (max-width: 640px) {
      .snapshot  { grid-template-columns: 1fr 1fr; }
      .gauge-grid { grid-template-columns: 1fr; }
      .oi-grid   { grid-template-columns: 1fr; }
      .zone-container { grid-template-columns: 1fr; }
      .zone-thermometer { display: none; }
      .toc-list  { grid-template-columns: 1fr; }
      .related-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
